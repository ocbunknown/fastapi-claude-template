{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/guard_paths.py"
          },
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/guard_layers.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/pre_commit_checks.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python .claude/hooks/ruff_fix.py"
          }
        ]
      }
    ]
  }
}
